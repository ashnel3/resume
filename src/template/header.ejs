<header class="page-header">
  <div class="page-header-profile">
    <img src="<%= context.profile %>" alt="Profile Image" />
    <h2><%= context.title %></h2>
  </div>
  <div class="page-header-info">
    <% for ([name, obj] of Object.entries(context.contact ?? {})) { %>
      <a class="link-icon" rel="noopener noreferrer" target="_blank" href="<%= obj.url %>">
        <%- include(obj.image) %>
        <span class="text-overflow-ellipsis"><%= obj.text %></span>
      </a>
    <% } %>
  </div>
  <div class="page-header-certifications">
    <h2 class="title">certifications:</h2>
    <% for (cert of context.certifications) { %>
      <a class="link-icon" href="<%= cert.url %>">
        <img src="<%= cert.image %>" alt="certification badge" />
        <span>
          <h4 class="text-overflow-ellipsis"><%- cert.title.replace('\n', '<br />') %></h4>
          <%- include('./partial/timestamp.ejs', { date: cert.date }) %>
        </span>
      </a>
    <% } %>
  </div>
</header>
